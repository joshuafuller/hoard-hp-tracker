{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": ["scripts/*.mjs", "e2e/**/*.spec.ts"],
  "project": ["src/**/*.{ts,tsx}", "scripts/**/*.mjs", "e2e/**/*.ts"],
  "ignoreDependencies": ["@3d-dice/dice-box"],
  "ignoreBinaries": ["ffmpeg"],
  "rules": {
    "files": "error",
    "dependencies": "error",
    "devDependencies": "error",
    "unlisted": "error",
    "binaries": "error",
    "unresolved": "error",
    "exports": "warn",
    "types": "warn",
    "nsExports": "warn",
    "nsTypes": "warn",
    "duplicates": "warn",
    "enumMembers": "warn",
    "classMembers": "warn"
  }
}
