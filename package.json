{
  "name": "hoard-hp-tracker",
  "version": "0.0.15",
  "private": true,
  "type": "module",
  "description": "A gorgeous, offline-capable fullscreen HP tracker PWA for tabletop games (AGPL-3.0).",
  "license": "AGPL-3.0-only",
  "packageManager": "pnpm@10.30.2",
  "scripts": {
    "prepare": "node scripts/setup-hooks.mjs",
    "vendor:dice": "node scripts/vendor-dice.mjs",
    "dev": "node scripts/vendor-dice.mjs && vite",
    "build": "node scripts/vendor-dice.mjs && tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "typecheck:e2e": "tsc -p tsconfig.e2e.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "mutation": "stryker run",
    "knip": "knip"
  },
  "dependencies": {
    "@3d-dice/dice-box": "^1.1.4",
    "@3d-dice/dice-parser-interface": "^0.2.1",
    "dexie": "^4.0.10",
    "dexie-react-hooks": "^1.1.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "1.60.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "fake-indexeddb": "^6.0.0",
    "fast-check": "^3.23.1",
    "globals": "^15.14.0",
    "jsdom": "^25.0.1",
    "knip": "^6.18.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^6.0.5",
    "vite-plugin-pwa": "^0.21.1",
    "vitest": "^3.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "qs@>=6.11.1 <=6.15.1": "6.15.2"
    }
  }
}
