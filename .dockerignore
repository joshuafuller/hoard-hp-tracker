# Keep the Docker build context small + reproducible: exclude everything generated or
# machine-local. The image installs deps clean (pnpm --frozen-lockfile) and runs `pnpm
# build`, which regenerates dist/ AND public/dice/ (scripts/vendor-dice.mjs) inside the
# container — so none of the host's artifacts are needed, and copying host node_modules
# (built for another platform) over the clean install would actively harm the build (#259).

# Dependencies (reinstalled clean in the image)
node_modules/

# Build output (regenerated by `pnpm build`)
dist/
dev-dist/
*.tsbuildinfo

# Vendored dice-box dist (regenerated by scripts/vendor-dice.mjs during build)
public/dice/

# Test + mutation tooling output
reports/
test-results/
playwright-report/
.stryker-tmp/
coverage/

# Version control + CI config (not needed to build the app)
.git/
.github/
.gitignore

# Tooling / brainstorming scratch
.gstack/
.superpowers/

# Editor / OS files
.DS_Store
.idea/
.vscode/
*.swp

# Logs + secrets
*.log
npm-debug.log*
.env
.env.*

# Docker files themselves
Dockerfile
.dockerignore
